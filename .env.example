# Veritabanı (SQLite)
# Geliştirme:   file:./prisma/dev.db
# Production:   file:./prisma/prod.db  veya mutlak yol: file:C:/guleryuz/data/prod.db
DATABASE_URL="file:./prisma/dev.db"

# Auth.js — npx auth secret ile üret
AUTH_SECRET="buraya-gizli-anahtar-yaz"

# Google OAuth — console.cloud.google.com'dan al
# Auth.js v5'te GOOGLE_ prefix kullanılıyor (AUTH_GOOGLE_ değil)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Site URL (Open Graph, sitemap, email linkleri için — production'da domain/IP ile değiştir)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Email (Resend — resend.com'dan API key al)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@guleryuzgayrimenkul.com"

# İlk süper admin — seed.ts için (production'da MUTLAKA değiştir)
SEED_ADMIN_EMAIL="admin@guleryuzgayrimenkul.com"
SEED_ADMIN_PASSWORD="GucluBirSifreYaz123!"
SEED_ADMIN_NAME="Sistem Yöneticisi"
