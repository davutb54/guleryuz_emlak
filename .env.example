# Veritabanı (SQLite)
DATABASE_URL="file:./prisma/dev.db"

# Auth.js — npx auth secret ile üret
AUTH_SECRET="buraya-gizli-anahtar-yaz"

# Google OAuth — console.cloud.google.com'dan al
# Auth.js v5'te GOOGLE_ prefix kullanılıyor (AUTH_GOOGLE_ değil)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Email (Resend — opsiyonel, Faz 4'te aktif edilecek)
# RESEND_API_KEY=""
# RESEND_FROM_EMAIL="noreply@guleryuzgayrimenkul.com"

# İlk süper admin (seed.ts için)
ADMIN_EMAIL="admin@guleryuzgayrimenkul.com"
